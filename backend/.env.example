# ──────────────────────────────────────────────────────────────
# Agentic RAG Chatbot — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# ── LLM: Groq (free tier) ─────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here
LLM_MODEL=llama-3.3-70b-versatile

# ── Embeddings: Gemini (free tier, 768-dim) ───────────────────
GEMINI_API_KEY=AIza_your_gemini_key_here
GEMINI_EMBED_MODEL=models/text-embedding-004

# ── Vector DB: Supabase ───────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ_your_service_role_key_here

# ── LangSmith Tracing (optional but recommended for portfolio) ─
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your_langsmith_key_here
LANGCHAIN_PROJECT=Agentic-RAG-Chatbot

# ── SQLite (short-term memory checkpointer) ───────────────────
SQLITE_DB_PATH=chatbot.db

# ── Optional: Alpha Vantage stock price tool ──────────────────
ALPHAVANTAGE_API_KEY=your_alpha_vantage_key_here

# ── OpenRouter (kept as fallback, not used by default) ────────
# OPENROUTER_API_KEY=sk-or-your_key_here
